# Environment variables for IT Desk API
# Copy this file to .env and fill in the values.
# NEVER commit .env to git — it contains secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Your PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Get this from Railway/Render after provisioning a Postgres instance.
DATABASE_URL="postgresql://postgres:password@localhost:5432/itdesk"

# ── Auth ──────────────────────────────────────────────────────────────────────
# SESSION_SECRET — any long random string. Used to sign the session ID cookie
# so it can't be tampered with (the cookie itself holds no user data — just a
# random ID that's looked up in the Session table on every request).
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET="replace_with_a_long_random_string"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# NODE_ENV controls the session cookie's Secure/SameSite settings (see index.js).
# Render sets this to "production" automatically — you don't need to set it
# yourself in production, only if you want to test that behavior locally.
# NODE_ENV=production

# ── Frontend URL (used in report link generation + CORS) ──────────────────────
# In development: http://localhost:3000
# In production: your Vercel URL. Must be an exact match — no trailing slash —
# since it's also used to build the CORS allow-list for cross-origin cookies.
CLIENT_URL="http://localhost:3000"
