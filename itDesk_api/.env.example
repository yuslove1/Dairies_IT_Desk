# Environment variables for IT Desk API
# Copy this file to .env and fill in the values.
# NEVER commit .env to git — it contains secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Your PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Get this from Railway/Render after provisioning a Postgres instance.
DATABASE_URL="postgresql://postgres:password@localhost:5432/itdesk"

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT_SECRET — any long random string. Used to sign and verify tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace_with_a_long_random_string"

# How long tokens stay valid. Format: "7d", "24h", "1h"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# ── Frontend URL (used in report link generation) ─────────────────────────────
# In development: http://localhost:3000
# In production: your Vercel/Netlify URL
CLIENT_URL="http://localhost:3000"
